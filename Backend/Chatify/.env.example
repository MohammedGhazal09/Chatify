NODE_ENV=development
PORT=5000
PORT_NUMBER=5000

MONGODB_URL=mongodb://127.0.0.1:27017/chatify
SECRET_JWT_KEY=replace-with-a-long-random-jwt-secret
EXPIRES_IN=15m
ACCESS_TOKEN_EXPIRES_IN=15m
CSRF_SECRET=replace-with-a-long-random-csrf-secret
PASSWORD_RESET_SECRET=replace-with-a-long-random-reset-secret

FRONTEND_ORIGIN=https://your-frontend.example.com
FRONTEND_ORIGIN_DEV=http://localhost:5173

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

EMAIL_USER_SENDER=chatify@example.com
BREVO_API_KEY=your-brevo-api-key

CHATIFY_DELIVERY_DIAGNOSTICS=0
CHATIFY_LOG_LEVEL=info
CHATIFY_TEST_LOGS=0
CHATIFY_CALL_DISCONNECT_GRACE_MS=10000

CALL_STUN_URLS=stun:stun.l.google.com:19302
CALL_TURN_URLS=
CALL_TURN_USERNAME=
CALL_TURN_CREDENTIAL=
